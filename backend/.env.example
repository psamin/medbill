FLASK_ENV=development
FLASK_RUN_PORT=5001

# Generate a strong random value for production
SECRET_KEY=dev-secret-change-me

DATABASE_URL=sqlite:///app.db
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:3000
SESSION_TTL_SECONDS=86400
MAX_UPLOAD_MB=10

# CMS Medicare rates API (public, no key needed)
CMS_API_URL=https://data.cms.gov/data-api/v1/dataset/6fea9d79-0129-4e4c-b1b8-23cd86a4f435/data
CMS_API_KEY=

# Anthropic — required for messy PDF fallback extraction
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
