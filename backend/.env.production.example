# Copy this to .env for production (never commit the real .env file)
FLASK_ENV=production

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_HEX_32

# ── Database ──────────────────────────────────────────────────────────────────
# Cloud SQL Postgres (recommended — survives redeployment)
DATABASE_URL=postgresql+psycopg2://medbill:PASSWORD@/medbill?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
# SQLite fallback (demo/test only — data lost on Cloud Run redeployment)
# DATABASE_URL=sqlite:///app.db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Memorystore private IP (from GCP console → Memorystore → your instance)
REDIS_URL=redis://10.x.x.x:6379/0
# Redis Cloud free-tier alternative:
# REDIS_URL=redis://default:PASSWORD@host.redns.redis-cloud.com:PORT/0
SESSION_TTL_SECONDS=86400

# ── CORS ──────────────────────────────────────────────────────────────────────
# Deployed frontend URL — no trailing slash
FRONTEND_URL=https://medbill-frontend-xxxx-uc.a.run.app

# ── Upload limit ──────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10

# ── Funding math (do not change without business approval) ────────────────────
DEFAULT_NEGOTIATED_RATE_MULTIPLIER=1.00
FUNDER_MEDICARE_MULTIPLIER=1.60
LAW_FIRM_SPREAD_PERCENT=0.60

# ── AI extraction ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001
CLAUDE_EXTRACTION_FALLBACK_MODEL=claude-sonnet-4-6

# ── CMS Medicare rates ────────────────────────────────────────────────────────
CMS_API_URL=https://data.cms.gov/data-api/v1/dataset/6fea9d79-0129-4e4c-b1b8-23cd86a4f435/data
CMS_API_KEY=
RATE_CACHE_TTL_SECONDS=86400
