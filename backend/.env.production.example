# Copy this to .env (never commit the real file)
FLASK_ENV=production
FLASK_RUN_PORT=8080

# Database — use Cloud SQL Postgres in production
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Redis — use Cloud Memorystore or a small Redis Cloud instance for testing
REDIS_URL=redis://10.x.x.x:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string

# CORS — set to your deployed frontend URL
FRONTEND_URL=https://medbill-frontend-HASH-uc.a.run.app

# Session
SESSION_TTL_SECONDS=86400

# Upload limit
MAX_UPLOAD_MB=10

# Funding math constants
DEFAULT_NEGOTIATED_RATE_MULTIPLIER=1.00
FUNDER_MEDICARE_MULTIPLIER=1.60
LAW_FIRM_SPREAD_PERCENT=0.60

# AI extraction fallback
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# CMS Medicare API
CMS_API_URL=https://data.cms.gov/data-api/v1/dataset/6fea9d79-0129-4e4c-b1b8-23cd86a4f435/data
CMS_API_KEY=
RATE_CACHE_TTL_SECONDS=86400
